# Gharka Chef backend example environment variables
# Copy this file to .env and fill values before running the server.

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gharka_chef
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# SMTP / Email (Gmail example uses App Password)
SMTP_ENABLE=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM="Gharka Chef <no-reply@yourdomain.com>"
SMTP_USE_TLS=true

# Dev helpers
DEV_RETURN_OTP=false

APP_NAME="Gharka Chef API"
CORS_ALLOW_ORIGINS='["http://localhost:3005"]'
OPENAI_API_KEY="your_api_key_here"
OPENAI_MODEL="gpt-5-mini"
OPENAI_IMAGE_MODEL="gpt-image-1"
